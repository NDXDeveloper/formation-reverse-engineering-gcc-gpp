# ===========================================================================
#  .gitignore — Formation Reverse Engineering (GCC/G++)
#
#  Stratégie : on ignore TOUT dans binaries/ puis on ré-inclut
#  uniquement les sources, Makefiles et fichiers de config.
#  C'est la méthode la plus robuste — tout nouveau binaire compilé
#  sera automatiquement ignoré.
# ===========================================================================

# ── BINAIRES : tout ignorer puis ré-inclure les sources ───────────────────

# Étape 1 : ignorer tout dans binaries/
binaries/**

# Étape 2 : ré-inclure les répertoires (nécessaire pour la traversée)
!binaries/
!binaries/*/
!binaries/**/

# Étape 3 : ré-inclure les fichiers sources et de config
!binaries/Makefile
!binaries/*/Makefile
!binaries/**/*.c
!binaries/**/*.cpp
!binaries/**/*.h
!binaries/**/*.cs
!binaries/**/*.csproj
!binaries/**/*.rs
!binaries/**/*.go
!binaries/**/go.mod
!binaries/**/go.sum
!binaries/**/Cargo.toml
!binaries/**/Cargo.lock
!binaries/**/*.json
!binaries/**/*.md

# ── Fichiers .locked produits par le ransomware (ch27) ────────────────────
*.locked
README_LOCKED.txt

# ── .NET (obj, bin, NuGet caches) — au cas où ré-inclus par erreur ───────
**/obj/
**/bin/Release/
**/bin/Debug/

# ── Rust ──────────────────────────────────────────────────────────────────
**/target/

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
*.egg-info/
venv/
.venv/

# ── Éditeurs et IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── GDB ───────────────────────────────────────────────────────────────────
.gdb_history
core
core.*

# ── Ghidra (projets locaux) ──────────────────────────────────────────────
*.gpr
*.rep/

# ── ImHex (projets locaux) ───────────────────────────────────────────────
*.hexproj

# ── Captures réseau ──────────────────────────────────────────────────────
*.pcap
*.pcapng

# ── Archives de samples (convention malware analysis) ────────────────────
*.zip.malware
*.infected

